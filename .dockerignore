# NOTE: node_modules is intentionally NOT ignored. The build network can't
# reach the npm registry reliably, so the Docker build reuses the locally
# installed node_modules instead of running `npm ci`. The local tree ships both
# the glibc and musl @next/swc binaries, so it works in the Alpine image.

# Build output / caches — regenerated by `npm run build` inside the image.
.next
.turbo

# Git + VCS
.git
.gitignore

# Local/editor/OS cruft
*.log
npm-debug.log*
.DS_Store
.vscode
.idea

# Docker + docs (not needed inside the image)
Dockerfile
docker-compose.yml
README.md

# NOTE: .env is intentionally NOT ignored — `next build` reads NEXT_PUBLIC_*
# from it at build time to inline them into the client bundle.
