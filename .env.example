# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# ── Browser-facing base ───────────────────────────────────────────────────────
# The browser calls the same-origin proxy at /api/proxy/* (see
# app/api/proxy/[...path]/route.ts); it never calls the backend directly.
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# ── Server-side upstreams (read by the proxy, never exposed to the browser) ───
# Main backend: registration, auth, profile, /v1/lookup/* tables.
BACKEND_API_BASE_URL=https://backend.example.internal
AUTH_API_BASE_URL=https://backend.example.internal
# Same backend for the email-id route helper.
API_BASE_URL=https://backend.example.internal
# Optional bearer for the email-id helper route.
API_SECRET_KEY=
# Lookup microservice: serves /lookup/* directly (NO /api prefix) — the base
# must not include /api.
LOOKUP_API_BASE_URL=https://lookup.example.internal

# Auth mock switch. MUST be "false" in production (the app refuses to start in
# production otherwise — see instrumentation.ts). Any other value mocks auth.
NEXT_PUBLIC_AUTH_BYPASS=false

# App version shown in the UI. Inlined into the client bundle at build time.
NEXT_PUBLIC_APP_VERSION=0.0.0

# ── Diagnostics ───────────────────────────────────────────────────────────────
# Set to "true" ONLY to log proxied request/response BODIES to the server
# console. Leave unset in production: bodies contain PII. Status-line logs
# (method, path, status, latency) are always emitted regardless.
DEBUG_PROXY=
