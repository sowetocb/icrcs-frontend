# ── Browser-facing base ───────────────────────────────────────────────────────
# The browser must NOT call the backend directly (CORS / mixed-content / the
# 10.232.x network isn't reachable from the client). Instead it calls the
# same-origin proxy at /api/proxy/*, which forwards server-side to the hosts
# below. See app/api/proxy/[...path]/route.ts.
NEXT_PUBLIC_API_BASE_URL=/api/proxy

# ── Server-side upstreams (read by the proxy, never exposed to the browser) ───
# Main backend: registration, auth, profile, /v1/lookup/* tables.
BACKEND_API_BASE_URL=http://10.232.0.12:1010/api
AUTH_API_BASE_URL=http://10.232.0.12:1010/api
# Same backend for the email-id route helper.
API_BASE_URL=http://10.232.0.12:1010/api
# Lookup microservice: geographic cascade + demographic enums. It serves paths
# under /lookup/* directly (NO /api prefix), so the base must not include /api —
# the proxy appends the full /lookup/... path the client requests.
LOOKUP_API_BASE_URL=http://10.232.0.12:7001

# Hit the real backend instead of the in-app mocks. When unset (or anything
# other than "false") the app short-circuits every submission with a mock.
NEXT_PUBLIC_AUTH_BYPASS=false

# App version shown in the UI (e.g. login footer). Keep in sync with the Docker
# image tag. Inlined into the client bundle at build time.
NEXT_PUBLIC_APP_VERSION=0.0.7

